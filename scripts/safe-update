#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"

while [[ -L "$SOURCE_PATH" ]]; do
    SCRIPT_DIR=$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)
    SOURCE_PATH=$(readlink "$SOURCE_PATH")
    if [[ "$SOURCE_PATH" != /* ]]; then
        SOURCE_PATH="$SCRIPT_DIR/$SOURCE_PATH"
    fi
done

SCRIPT_DIR=$(cd -P "$(dirname "$SOURCE_PATH")" && pwd)
REPO_ROOT=$(cd "$SCRIPT_DIR/.." && pwd)

source "$REPO_ROOT/lib/utils.sh"
source "$REPO_ROOT/lib/config.sh"
source "$REPO_ROOT/lib/logging.sh"
source "$REPO_ROOT/lib/notifications.sh"
source "$REPO_ROOT/lib/snapshots.sh"
source "$REPO_ROOT/lib/risk.sh"
source "$REPO_ROOT/lib/reports.sh"

main() {
    init_config "$REPO_ROOT"
    ensure_runtime_dirs
    init_logging

    section "Safe Update Started"

    verify_update_detection_prereqs

    local updates
    if ! updates=$(detect_updates); then
        write_report "detect-failed" "" "$REBOOT_REQUIRED"
        exit 1
    fi

    if [[ -z "$updates" ]]; then
        log "System already up to date."
        write_report "no-updates" "" "false"
        exit 0
    fi

    section "Pending Updates"
    printf '%s\n' "$updates" | tee -a "$LOG_FILE"

    section "Risk Analysis"
    analyze_updates "$updates"
    print_risk_summary

    if risk_bucket_has_entries "CRITICAL"; then
        warn "Critical system updates detected."
        log "Review recommended before continuing."
        notify_if_enabled "safe-update" "Critical updates detected"
    fi

    echo
    if ! read -rp "Proceed with update? [y/N]: " CONFIRM; then
        error "Confirmation prompt failed. Run safe-update from an interactive terminal."
        write_report "prompt-failed" "" "$REBOOT_REQUIRED"
        exit 1
    fi

    if ! is_yes "$CONFIRM"; then
        log "Update cancelled by user."
        write_report "cancelled" "" "$REBOOT_REQUIRED"
        exit 0
    fi

    verify_update_execution_prereqs
    create_snapshot
    run_updates
    reboot_check
    write_report "success" "$SNAPSHOT_NAME" "$REBOOT_REQUIRED"

    section "Safe Update Complete"
}

detect_updates() {
    local output
    local error_output
    local status=0
    local stdout_file
    local stderr_file

    stdout_file=$(mktemp)
    stderr_file=$(mktemp)

    if "$PARU_BIN" -Qu >"$stdout_file" 2>"$stderr_file"; then
        status=0
    else
        status=$?
    fi

    output=$(cat "$stdout_file")
    error_output=$(cat "$stderr_file")
    rm -f "$stdout_file" "$stderr_file"

    if [[ "$status" -eq 0 ]]; then
        printf '%s\n' "$output"
        return 0
    fi

    if [[ "$status" -eq 1 && -z "$output" && -z "$error_output" ]]; then
        return 0
    fi

    error "Failed to query pending updates with paru -Qu"
    if [[ -n "$error_output" ]]; then
        printf '%s\n' "$error_output" | tee -a "$LOG_FILE" >&2
    fi
    if [[ -n "$output" ]]; then
        printf '%s\n' "$output" | tee -a "$LOG_FILE" >&2
    fi
    return 1
}

run_updates() {
    section "Running Updates"
    "$PARU_BIN" -Syu
}

verify_update_detection_prereqs() {
    if ! have_command "$PARU_BIN"; then
        error "Missing required command: $PARU_BIN"
        write_report "missing-prereqs" "" "$REBOOT_REQUIRED"
        exit 1
    fi

    if bool_is_true "$ENABLE_NOTIFICATIONS" && ! have_command "$NOTIFY_SEND_BIN"; then
        log "Notification support unavailable: notify-send not found"
    fi
}

verify_update_execution_prereqs() {
    local missing=()

    if ! have_command "$SUDO_BIN"; then
        missing+=("$SUDO_BIN")
    fi

    if ! have_command "$SNAPPER_BIN"; then
        missing+=("$SNAPPER_BIN")
    fi

    if [[ "${#missing[@]}" -gt 0 ]]; then
        error "Missing required command(s) for update execution: ${missing[*]}"
        write_report "missing-prereqs" "" "$REBOOT_REQUIRED"
        exit 1
    fi
}

reboot_check() {
    section "Reboot Check"

    if [[ "$REBOOT_REQUIRED" == "true" ]]; then
        warn "Reboot recommended"
        notify_if_enabled "safe-update" "Reboot recommended after updates"
    else
        log "No reboot required"
    fi
}

main "$@"
